# Candela environment variables
# Copy this file to .env (production) or .env.dev (local development)

# -- Database --
# Production (PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://candela:password@localhost/candela
# Development (SQLite, no Postgres required):
#   DATABASE_URL=sqlite+aiosqlite:///./candela.db
DATABASE_URL=sqlite+aiosqlite:///./candela.db

# -- Inverter --
# IP address of the WiNet-S2 module on your LAN
INVERTER_HOST=192.168.1.100

# Poll interval in seconds. Do NOT go below 30 — WiNet-S2 drops offline under
# aggressive polling. Default 300 (5 minutes) is recommended.
INVERTER_POLL_INTERVAL_SECONDS=300

# -- AEMO wholesale pricing --
AEMO_REGION=QLD1

# Network + environmental levy + retail cost stack estimate in c/kWh.
# Added on top of raw AEMO wholesale price to approximate Amber Electric pricing.
WHOLESALE_ADDER_CENTS_KWH=18.0

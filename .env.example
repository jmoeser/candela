# Candela environment variables
# Copy this file to .env (production) or .env.dev (local development)

# -- Database --
# Production (PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://candela:password@localhost/candela
# Development (SQLite, no Postgres required):
#   DATABASE_URL=sqlite+aiosqlite:///./candela.db
DATABASE_URL=sqlite+aiosqlite:///./candela.db

# -- Auth --
SECRET_KEY=changeme
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Optional bearer token for API access
# API_KEY=

# -- iSolarCloud --
ISOLARCLOUD_APP_KEY=
ISOLARCLOUD_ACCESS_KEY=
ISOLARCLOUD_USERNAME=
ISOLARCLOUD_PASSWORD=

# Override the default API endpoint (optional)
# ISOLARCLOUD_BASE_URL=https://augateway.isolarcloud.com

# Poll interval in seconds (minimum 300). Default 300 (5 minutes).
# ISOLARCLOUD_POLL_INTERVAL_SECONDS=300

# -- AEMO wholesale pricing --
# AEMO_REGION=QLD1
